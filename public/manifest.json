{
	"name": "Daily Quotes",
	"short_name": "Quotes",
	"description": "A retro pixelated Progressive Web App for managing daily quotes",
	"start_url": "/",
	"scope": "/",
	"display": "standalone",
	"display_override": ["standalone", "minimal-ui"],
	"background_color": "#000080",
	"theme_color": "#FF00FF",
	"icons": [
		{ "src": "/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
		{ "src": "/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" }
	],
	"shortcuts": [
		{
			"name": "Open Quotes",
			"short_name": "Open",
			"description": "Open the quote viewer",
			"url": "/?source=shortcut",
			"icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
		},
		{
			"name": "Add Quote",
			"short_name": "Add",
			"description": "Open the add-quote dialog",
			"url": "/?action=add",
			"icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
		}
	]
}
